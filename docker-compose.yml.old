networks:
  llama-net:

services:
  llm-model-manager:
    build:
      context: .
      dockerfile: Dockerfile
    image: local/llm-model-manager:latest
    container_name: llm-model-manager
    restart: unless-stopped
    environment:
      - LLAMA_CONTAINER_NAME=llama-cpp
      - HF_TOKEN=${HF_TOKEN}
      # - LOG_LEVEL=DEBUG # Uncomment for verbose logging
    ports:
      - "8000:8000"
    volumes:
      - ${MODELS}:/models
      - /var/run/docker.sock:/var/run/docker.sock
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    labels:
      - "com.centurylinklabs.watchtower.enable=false"

  llama-cpp:
    image: custom-llama-rpc
    container_name: llama-cpp
    restart: unless-stopped
    environment:
      - LLAMA_CACHE=/models
    ports:
      - 8080:8081
    networks:
      - llama-net
    volumes:
      - ${MODELS}:/models
    command: >
      --models-preset /models/served/models.ini
      --models-max 4
      --host 0.0.0.0
      --port 8081
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    labels:
      - "com.centurylinklabs.watchtower.enable=false"