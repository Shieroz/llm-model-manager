# Stage 1: Build llama-server with Vulkan support
FROM nvidia/cuda:13.1.0-devel-ubuntu24.04 AS builder

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
RUN git clone https://github.com/ggml-org/llama.cpp.git .

# Build with Vulkan support
RUN cmake -B build \
    -DGGML_VULKAN=ON \
    -DGGML_RPC=ON \
    -DCMAKE_BUILD_TYPE=Release \
    && cmake --build build --config Release -j$(nproc) --target llama-server

# Stage 2: Vulkan runtime + llama-swap binary + custom llama-server
FROM nvidia/cuda:13.1.0-runtime-ubuntu24.04

RUN apt-get update && apt-get install -y \
    libcurl4 \
    libgomp1 \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/mostlygeek/llama-swap:vulkan /app/llama-swap /usr/local/bin/llama-swap
COPY --from=builder /app/build/bin/llama-server /usr/local/bin/llama-server

ENTRYPOINT ["llama-swap"]